{
  "name": "follow-plan-mcp",
  "version": "1.0.0",
  "description": "MCP Server for AI implementation plan tracking and context management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "follow-plan-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "jest:esm": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config=jest.config.mjs",
    "test": "npm run jest:esm",
    "test:watch": "npm run jest:esm -- --watch",
    "test:coverage": "npm run jest:esm -- --coverage",
    "test:ci": "npm run jest:esm -- --ci --coverage --watchAll=false",
    "test:unit": "npm run jest:esm -- --testPathPattern=unit",
    "test:integration": "npm run jest:esm -- --testPathPattern=integration",
    "test:security": "npm run jest:esm -- --testPathPattern=security",
    "test:edge-cases": "npm run jest:esm -- --testPathPattern=edge-cases",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:ci && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "project-management",
    "implementation-tracking",
    "claude",
    "anthropic"
  ],
  "author": "Marco Antonio Gonzalez Junior <m@rco.sh>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "@jest/globals": "^29.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibeclasses/follow-plan-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vibeclasses/follow-plan-mcp/issues"
  },
  "homepage": "https://github.com/vibeclasses/follow-plan-mcp#readme"
}
