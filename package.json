{
  "name": "follow-plan-mcp",
  "version": "1.0.0",
  "description": "MCP Server for AI implementation plan tracking and context management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "follow-plan-mcp": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:security": "jest --testPathPattern=security",
    "test:edge-cases": "jest --testPathPattern=edge-cases",
    "prepare": "npm run build",
    "prepublishOnly": "npm run test:ci && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "project-management",
    "implementation-tracking",
    "claude",
    "anthropic"
  ],
  "author": "Marco Antonio Gonzalez Junior <m@rco.sh>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "i": "^0.3.7",
    "jest": "^29.0.0",
    "npm": "^11.4.2",
    "prettier": "^3.0.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibeclasses/follow-plan-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vibeclasses/follow-plan-mcp/issues"
  },
  "homepage": "https://github.com/vibeclasses/follow-plan-mcp#readme"
}
